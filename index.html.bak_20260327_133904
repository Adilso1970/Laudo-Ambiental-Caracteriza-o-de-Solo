<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CARACTERIZAÇÃO DE SOLO - N.E.</title>
  <link rel="manifest" href="manifest.webmanifest" />
  <link rel="stylesheet" href="styles/app.css" />
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand">
        <img class="brandLogo" src="data:image/webp;base64," alt="Marca NB" />
        <div class="brandText">
          <h1>CARACTERIZAÇÃO DE SOLO</h1>
        </div>
      </div>

      <nav id="nav" class="nav"></nav>

      <div class="sideBottom">
        <div id="routeIndicator" class="badge secondary shellBadge">Módulo: Projetos</div>
        <div class="small" id="projectStatus">Projeto atual: nenhum</div>
        <div class="small" id="onlineStatus">Status: verificando…</div>
        <div class="small">GPS: <span id="gpsStatus">—</span></div>
        <div class="small">Versão: <span id="appVersion"></span></div>
      </div>
    </aside>

    <main class="main">
      <div class="container">
        <div id="toast" class="toast" hidden></div>
        <section id="app" class="card appShell"></section>
      </div>
      <footer class="footer"></footer>
    </main>
  </div>

  <script type="module" src="app.js"></script>
  <script type="module" src="auth_bootstrap.js"></script>
</body>
</html>


